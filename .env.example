# ─────────────────────────────────────────────────────────
# Frontend Environment Variables (.env.example)
# Copy this file to .env.local for local development,
# or set these in your Vercel project dashboard.
# ─────────────────────────────────────────────────────────

# API base URL for the backend
# • Local dev: leave blank — Vite proxy handles /api → localhost:5000
# • Vercel production: set to your Render backend URL
# Example: VITE_API_URL=https://fifa-prediction-api.onrender.com/api
VITE_API_URL=
