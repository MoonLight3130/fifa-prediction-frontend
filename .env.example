# ─────────────────────────────────────────────────────────────────────────────
# Frontend Environment Variables (.env.example)
# Copy this file to .env.local for local development.
# Set these in your Vercel project dashboard for production.
# ─────────────────────────────────────────────────────────────────────────────

# ── Production (Vercel) ───────────────────────────────────────────────────────
# Set this to your Render backend URL in the Vercel dashboard.
# Example: https://fifa-prediction-backend-bakh.onrender.com/api
VITE_API_URL=

# ── Local Development ─────────────────────────────────────────────────────────
# Leave VITE_API_URL blank to use the Vite dev proxy (routes /api → localhost:5000).
# OR set VITE_PROXY_TARGET to point the proxy at Render instead of localhost.
# VITE_PROXY_TARGET=https://fifa-prediction-backend-bakh.onrender.com
